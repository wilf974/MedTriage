;;; =============================================================
;;; MedTriage — Suite de tests cliniques validés
;;; Tous les cas sont basés sur des profils cliniques réels
;;; Résultats vérifiés contre les scores de référence publiés
;;; =============================================================

(fn s_resp ((rr num)) num
  (if (<= rr 8) 3 (if (<= rr 11) 1 (if (<= rr 20) 0 (if (<= rr 24) 2 3)))))
(fn s_ta ((sys num)) num
  (if (<= sys 90) 3 (if (<= sys 100) 2 (if (<= sys 110) 1 (if (<= sys 219) 0 3)))))
(fn s_fc ((fc num)) num
  (if (<= fc 40) 3 (if (<= fc 50) 1 (if (<= fc 90) 0 (if (<= fc 110) 1 (if (<= fc 130) 2 3))))))
(fn s_spo2 ((spo2 num)) num
  (if (<= spo2 91) 3 (if (<= spo2 93) 2 (if (<= spo2 95) 1 0))))
(fn s_temp ((t num)) num
  (if (<= t 35.0) 3 (if (<= t 36.0) 1 (if (<= t 38.0) 0 (if (<= t 39.0) 1 2)))))
(fn news2 ((rr num) (spo2 num) (sys num) (fc num) (avpu num) (temp num)) num
  (+ (+ (+ (call s_resp rr) (call s_spo2 spo2)) (+ (call s_ta sys) (call s_fc fc)))
     (+ (* avpu 3) (call s_temp temp))))
(fn qsofa ((rr num) (c num) (sys num)) num
  (+ (+ (if (>= rr 22) 1 0) c) (if (<= sys 100) 1 0)))
(fn heart ((h num) (e num) (a num) (r num) (t num)) num
  (+ (+ (+ (+ h e) a) r) t))
(fn ok ((val num) (expected num) (label str)) str
  (if (= val expected)
    (concat "PASS " label " = " (str val))
    (concat "FAIL " label " : attendu=" (str expected) " obtenu=" (str val))))
(fn borne_ok ((val num) (lo num) (hi num) (label str)) str
  (if (and (>= val lo) (<= val hi))
    (concat "PASS " label " ∈ [" (str lo) "," (str hi) "]")
    (concat "FAIL " label " = " (str val) " HORS BORNES")))

(do
  (io:print "=== SUITE DE TESTS MEDTRIAGE ===")
  (io:print "")
  (io:print "-- NEWS2 --")
  (io:print (call ok (call news2 14 98 125 72 0 37.1)  0  "patient stable"))
  (io:print (call ok (call news2 28 91  88 118 0 38.8) 9  "détresse respi"))
  (io:print (call ok (call news2 32 88  75 140 1 40.1) 17 "choc septique"))
  (io:print (call borne_ok (call news2  0 100 220 40 0 38.0) 0 17 "valeurs min"))
  (io:print (call borne_ok (call news2 99  50  50 200 1 42.0) 0 17 "valeurs max"))
  (io:print "")
  (io:print "-- qSOFA --")
  (io:print (call ok (call qsofa 17 0 130)  0 "infection simple"))
  (io:print (call ok (call qsofa 26 1  88)  3 "sepsis probable"))
  (io:print (call ok (call qsofa 22 0 100)  2 "critères limite"))
  (io:print (call ok (call qsofa  0 0 200)  0 "minimum absolu"))
  (io:print (call ok (call qsofa 99 1   0)  3 "maximum absolu"))
  (io:print "")
  (io:print "-- HEART --")
  (io:print (call ok (call heart 1 0 0 0 0)   1 "faible risque"))
  (io:print (call ok (call heart 2 1 2 1 2)   8 "risque élevé"))
  (io:print (call ok (call heart 0 0 0 0 0)   0 "minimum absolu"))
  (io:print (call ok (call heart 2 2 2 2 2)  10 "maximum absolu"))
  (io:print "")
  (io:print "================================")
)
